直接给你一份“一键联调清单# tutor2 LLM
TUTOR2_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# sandbox endpoint
SANDBOX_API_URL=http://127.0.0.1:8002/api/sandbox/evaluate

# mysql for testcase agent
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=openclaw

# optional rag + embedding
TUTOR2_RAG_DOCS_DIR=./rag_docs
TUTOR2_RAG_INDEX_DIR=./data/rag_index
TUTOR2_TESTCASE_CACHE_CSV=./data/test_cases_cache.csv
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# langsmith observability (optional but recommended)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cppai-tutor2
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
